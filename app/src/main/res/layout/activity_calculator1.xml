<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6F5"
    android:padding="16dp"
    tools:context=".Calculator1">

    <!-- Header -->
    <androidx.cardview.widget.CardView
        android:id="@+id/headerCard"
        android:layout_width="0dp"
        android:layout_height="180dp"
        app:cardCornerRadius="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/header_gradient"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center">

            <TextView
                android:id="@+id/textViewGreenify"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Greenify"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/textViewMeatCalculator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Meat Calculator"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="8dp"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_gravity="bottom"
            android:background="@drawable/curved_bottom" />
    </androidx.cardview.widget.CardView>

    <!-- Navigation Buttons -->
    <LinearLayout
        android:id="@+id/navButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnTransport"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Transport"
            android:textSize="14sp"
            android:textColor="#2E7D32"
            android:background="@drawable/card_gradient"
            android:layout_marginEnd="8dp"
            tools:ignore="HardcodedText" />

        <Button
            android:id="@+id/btnFoodCalculator"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Food"
            android:textSize="14sp"
            android:textColor="#2E7D32"
            android:background="@drawable/card_gradient"
            android:layout_marginEnd="8dp"
            tools:ignore="HardcodedText" />

        <Button
            android:id="@+id/btngotoElectricity"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Electricity"
            android:textSize="14sp"
            android:textColor="#2E7D32"
            android:background="@drawable/card_gradient"
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <!-- Meat Type Dropdown -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/meatConsumedLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:hint="Type of meat"
        app:hintTextColor="#8D6E63"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="#4CAF50"
        app:layout_constraintTop_toBottomOf="@id/navButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/spinnerMeatType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:background="@null"
            android:cursorVisible="false"
            android:focusable="false"
            android:hint=""
            android:padding="12dp"
            android:textColor="#2E7D32"
            android:textColorHint="#8D6E63"
            tools:ignore="HardcodedText" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Weight Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/weightOfMeatLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:hintTextColor="#8D6E63"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="#4CAF50"
        app:layout_constraintTop_toBottomOf="@id/meatConsumedLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/weightofmeat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Weight of meat (kg)"
            android:inputType="numberDecimal"
            android:textColorHint="#8D6E63"
            android:textColor="#2E7D32"
            tools:ignore="HardcodedText" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:id="@+id/actionButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/weightOfMeatLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnCalculateMeat"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Calculate"
            android:textSize="16sp"
            android:textColor="#2E7D32"
            android:background="@drawable/card_gradient"
            android:layout_marginEnd="8dp"
            android:onClick="calculate"
            tools:ignore="HardcodedText" />

        <Button
            android:id="@+id/btnGenerateTips"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Get Tips"
            android:textSize="16sp"
            android:textColor="#2E7D32"
            android:background="@drawable/card_gradient"
            android:onClick="generateTips"
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <!-- Carbon Display -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/textInputLayoutCarbonDisplay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="#4CAF50"
        app:layout_constraintTop_toBottomOf="@id/actionButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/carbondisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Carbon Emissions (kg CO2)"
            android:textColor="#2E7D32"
            android:textColorHint="#8D6E63"
            android:enabled="false"
            android:backgroundTint="#E8F5E9"
            tools:ignore="HardcodedText" />
    </com.google.android.material.textfield.TextInputLayout>

</androidx.constraintlayout.widget.ConstraintLayout>